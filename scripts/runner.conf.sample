# Sample config for setup-github-runner-multi.sh
# Copy to scripts/runner.conf and edit values

# GitHub Personal Access Token with repo scope
GITHUB_PAT=

# For single-repo script (setup-github-runner.sh), set exactly one owner/repo
# Example: mod-net/bridge
REPO=

# For multi-repo script (setup-github-runner-multi.sh), use a comma-separated list
# Example: mod-net/chain,mod-net/bridge
REPOS=

# Optional: runner labels
LABELS=self-hosted,linux,x64,modnet-runner

# Optional: base directory on host for all runner mounts
BASE_DIR=/home/github-runner/actions-runner

# Optional: runner docker image
IMAGE=tcardonne/github-runner:latest
