# =============================
# Project: Mod-Net Bridge
# Environment configuration (local only)
# =============================

# --- Network selection ---
NETWORK=sepolia
USE_JSON=false

# --- RPC endpoints (HTTP) ---
# Used by scripts like packages/hardhat/scripts/checkSupply.ts
ETHEREUM_RPC=<ethereum_rpc>
ETHEREUM_SEPOLIA_RPC=<ethereum_sepolia_rpc>
BASE_RPC=<base_rpc>
BASE_SEPOLIA_RPC=<base_sepolia_rpc>

# --- RPC endpoints (WebSocket) ---
ETHEREUM_RPC_WS=<ethereum_rpc_ws>
ETHEREUM_SEPOLIA_RPC_WS=<ethereum_sepolia_rpc_ws>
BASE_RPC_WS=<base_rpc_ws>
BASE_SEPOLIA_RPC_WS=<base_sepolia_rpc_ws>

# --- Accounts & Keys ---
# CAUTION: Testnet keys only. Do not commit this file.
DEPLOYER_PK=<deployer_pk>
OPERATOR_PK=<operator_pk>
# Foundry decimal representation (no 0x)
DEPLOYER_PK_DEC=<deployer_pk_dec>
# Some scripts may read PRIVATE_KEY; keep in sync with DEPLOYER_PK
PRIVATE_KEY=<private_key>

# --- L1/L2 Token & Bridge Config ---
L1_ADMIN=<l1_admin>
L1_TOKEN_NAME=<l1_token_name>
L1_TOKEN_SYMBOL=<l1_token_symbol>
L1_TOKEN=<l1_token>

L2_TOKEN_NAME=<l2_token_name>
L2_TOKEN_SYMBOL=<l2_token_symbol>
L2_TOKEN=<l2_token>

# Standard Bridge (Sepolia L1)
L1_STANDARD_BRIDGE=<l1_standard_bridge>

# --- Node bridge task (Subspace node integrated relayer) ---
# Enable/disable the relayer task inside the node
BRIDGE_ENABLE=false
# RPCs used by the relayer
BRIDGE_L1_RPC=${ETHEREUM_SEPOLIA_RPC}
BRIDGE_BASE_RPC=${BASE_SEPOLIA_RPC}
# Private key used by the node relayer EOA (hex 0x...)
BRIDGE_PK=${DEPLOYER_PK}
# Token and bridge wiring
BRIDGE_L1_TOKEN=${L1_TOKEN}
BRIDGE_L2_TOKEN=${L2_TOKEN}
BRIDGE_L1_BRIDGE=${L1_STANDARD_BRIDGE}
BRIDGE_L2_GAS=200000
# BridgeMinter contract address (after deploy)
BRIDGE_MINTER=<bridge_minter>
# Decimals for conversion Substrate -> ERC20
BRIDGE_SUBSTRATE_DECIMALS=12
BRIDGE_ERC20_DECIMALS=18

# --- Build/Runtime (Rust/WasM) ---
WASM_BUILD_TOOLCHAIN=nightly
RUST_BACKTRACE=1

# --- CI/CD & Runners ---
RUNNER_WORKSPACE=<runner_workspace>
RUNNER_TEMP=<runner_temp>

# --- Container Registry (avoid committing real credentials) ---
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=<github_username>
# Quote to prevent accidental variable expansions by tooling
DOCKER_PASSWORD=<github_password>
DOCKER_CONTAINER_REGISTRY_USER=<container_registry_user>
DOCKER_CONTAINER_REGISTRY_PASSWORD=<container_registry_password>

# --- GitHub (avoid committing real tokens) ---
GITHUB_USER_NAME=<github_user_name>
GITHUB_REPO_NAME=<github_repo_name>
GITHUB_PERSONAL_ACCESS_TOKEN=<personal_access_token>

# --- Coinbase Developer Platform (CDP) keys (sensitive) ---
CDP_API_KEY_ID=<api_key_id>
CDP_API_KEY_SECRET=<api_key_secret>
CDP_API_KEY_NAME=<api_key_name>
CDP_WALLET_ADDRESS=<wallet_address>
CDP_API_KEY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<private_key>\n-----END PRIVATE KEY-----"
CDP_WALLET_SECRET=<wallet_secret>